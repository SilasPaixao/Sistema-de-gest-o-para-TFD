# URL do aplicativo
APP_URL="MY_APP_URL"

# Conexão com o Banco de Dados PostgreSQL (Opcional - cai de volta para db.json se não configurado)
DATABASE_URL="postgresql://usuario:senha@host:port/nome_banco?sslmode=require"

# Chave Secreta para Tokens JWT (Recomendado para produção em VPS)
JWT_SECRET="sua_chave_secreta_super_segura_aqui"

# Configurações de Backup em Servidor de Armazenamento S3 (Opcional)
S3_BUCKET="your_bucket_name"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your_access_key_id"
S3_SECRET_ACCESS_KEY="your_secret_access_key"
S3_ENDPOINT="https://s3.your-vps-provider.com" # Opcional - deixe vazio para AWS padrão ou preencha para MinIO, Cloudflare R2, DO Spaces, etc.
